# Application
APP_HOST=127.0.0.1
APP_PORT=8080
APP_LOCALE=de-AT
APP_TIMEZONE=Europe/Vienna
APP_DATA_DIR=./data
APP_LOG_LEVEL=INFO
APP_DEMO_MODE=false

# Weather
WEATHER_ENABLED=true
WEATHER_LABEL=Zuhause
WEATHER_LATITUDE=48.2082
WEATHER_LONGITUDE=16.3738
