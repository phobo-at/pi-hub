# Calendar / CalDAV
CALENDAR_ENABLED=false
CALENDAR_URL=
CALENDAR_USERNAME=
CALENDAR_PASSWORD=
CALENDAR_NAME=
CALENDAR_TIMEOUT_SECONDS=10

# Spotify
SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_DEVICE_ID=
SPOTIFY_MARKET=AT
SPOTIFY_TIMEOUT_SECONDS=10

# Screensaver / Lightroom
SCREENSAVER_ENABLED=true
SCREENSAVER_IDLE_TIMEOUT_SECONDS=120
