# Optional local-only overrides for `smart-display-local`
# This file is loaded after `.env` and overrides it.

APP_HOST=127.0.0.1
APP_PORT=8090
APP_TIMEZONE=Europe/Vienna
APP_LOCALE=de-AT

# Useful if you want to expose the local test server on your LAN:
# APP_HOST=0.0.0.0

# If you want to try a real provider locally, override the local demo defaults here.
# WEATHER_ENABLED=true
# WEATHER_LATITUDE=48.2082
# WEATHER_LONGITUDE=16.3738

